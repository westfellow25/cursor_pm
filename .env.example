# ── Core ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./pulse.db
SECRET_KEY=change-me-to-a-random-string

# ── LLM providers ────────────────────────────────────
# Claude (Anthropic) — preferred for cluster labels, summaries, recommendations
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI — used for embeddings (required for high-quality clustering)
# Also serves as LLM fallback when ANTHROPIC_API_KEY is not set
OPENAI_API_KEY=sk-...

# ── Integrations (optional) ──────────────────────────
INTERCOM_ACCESS_TOKEN=
ZENDESK_SUBDOMAIN=
ZENDESK_API_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info
